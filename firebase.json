{
    "hosting": {
      "public": ".",
      "ignore": [
        "firebase.json",
        "firestore.rules",
        "storage.rules",
        ".firebaserc",
        "**/.*",
        "Content/**",
        "node_modules/**"
      ],
      "rewrites": [
        { "source": "/", "destination": "/Main.html" }
      ]
    },
    "firestore": {
      "rules": "firestore.rules"
    }
  }